# LMS — Environment Configuration Example
# Copy ke `.env` (root project) sebelum run.

# === Server ===
ENV=development                          # development | production
PORT=8200
TIMEZONE=Asia/Jakarta
LOG_LEVEL=info                           # debug | info | warn | error

# === Database (PostgreSQL) ===
# Server rdpkhorur PG runs on port 5435 (not default 5432).
DATABASE_URL=postgres://lms:lms@localhost:5435/lms?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME_MIN=30

# === Migration ===
# Set true HANYA di dev untuk iterasi cepat.
# Production WAJIB pake `migrate up` (golang-migrate).
AUTOMIGRATE=false

# === Auth (JWT) ===
JWT_SECRET_KEY=change-me-pls-at-least-32-bytes-random
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAY=7
BCRYPT_COST=12

# === Storage ===
STORAGE_DIR=./storage/uploads
MAX_TUGAS_FILE_MB=20
MAX_GAMBAR_SOAL_MB=5

# === Rate Limit ===
RATE_LIMIT_GLOBAL_PER_MIN=120
RATE_LIMIT_LOGIN_PER_15MIN=5
RATE_LIMIT_REFRESH_PER_MIN=10
RATE_LIMIT_KELAS_JOIN_PER_MIN=10
RATE_LIMIT_UPLOAD_PER_MIN=30

# === CORS (kosong = same-origin only) ===
CORS_ALLOWED_ORIGINS=

# === Static frontend ===
# Path absolute atau relatif dari WorkingDirectory ke `frontend/out/`.
FRONTEND_DIR=./frontend/out

# === Seed Admin (cmd/seed-admin) ===
# Hanya dipakai sekali, opsional (kalau kosong, CLI bakal interactive prompt).
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=
